---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>Web3 News Wire</title>
  <subtitle>Latest Web3 trends, especially Base</subtitle>
  <link href="https://news.800.works/feed.xml" rel="self" type="application/atom+xml"/>
  <link href="https://news.800.works/"/>
  <id>https://news.800.works/</id>
  {% set latest = collections.article | first %}
  {% if latest %}
  <updated>{{ latest.data.date | toISOString }}</updated>
  {% endif %}
  {% for article in collections.article %}
  <entry>
    <title>{{ article.data.title }}</title>
    <link href="https://news.800.works{{ article.url }}"/>
    <id>https://news.800.works{{ article.url }}</id>
    <updated>{{ article.data.date | toISOString }}</updated>
    <summary>{{ article.data.summary }}</summary>
    <author><name>{{ article.data.author }}</name></author>
    <content type="html"><![CDATA[{{ article.templateContent | safe }}]]></content>
  </entry>
  {% endfor %}
</feed>
