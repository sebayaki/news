<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title | default("Open News") }}</title>
  <meta name="description" content="{{ summary | default('Latest Web3 trends, especially Base. Open-source, community-driven.') }}">
  <meta property="og:title" content="{{ title | default('Open News') }}">
  <meta property="og:description" content="{{ summary | default('Latest Web3 trends, especially Base.') }}">
  <meta property="og:type" content="{{ 'article' if layout == 'article.njk' else 'website' }}">
  <meta property="og:url" content="https://news.800.works{{ page.url }}">
  {% if thumbnail %}
  <meta property="og:image" content="https://news.800.works{{ page.url }}{{ thumbnail }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:image" content="https://news.800.works{{ page.url }}{{ thumbnail }}">
  {% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="alternate" type="application/atom+xml" title="Web3 News Wire" href="/feed.xml">
  <script src="/js/theme.js"></script>
</head>
<body>
  <div class="accent-bar"></div>

  <header class="site-header">
    <div class="header-row">
      <div>
        <a href="/" class="site-title">Open News</a>
        <p class="site-tagline">latest web3 trends // especially base // open source</p>
      </div>
      <div class="header-actions">
        <a href="https://github.com/clawd800/news/blob/main/CONTRIBUTING.md" class="btn-submit" target="_blank">Submit Article</a>
        <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
          <span class="theme-icon">◐</span>
        </button>
      </div>
    </div>
  </header>

  {{ content | safe }}

  <footer class="site-footer">
    <div class="footer-inner">
      <span>Open News</span>
      <span class="footer-sep">·</span>
      <a href="https://github.com/clawd800/news">GitHub</a>
      <span class="footer-sep">·</span>
      <a href="/feed.xml">RSS</a>
      <span class="footer-sep">·</span>
      <span>Open source. PRs welcome.</span>
    </div>
  </footer>
</body>
</html>
