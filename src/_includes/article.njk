---
layout: base.njk
---
<main class="article-page">
  <article class="article-content">
    <header class="article-header">
      <div class="article-date-back">
        <a href="/">&larr; back</a>
        <time>{{ date | readableDate }}</time>
      </div>
      <h1>{{ title }}</h1>
      {% if video %}
      <div class="article-hero">
        <video src="{{ page.url }}{{ video }}" autoplay loop muted playsinline></video>
      </div>
      {% elif thumbnail %}
      <div class="article-hero">
        <img src="{{ page.url }}{{ thumbnail }}" alt="{{ title }}" loading="lazy">
      </div>
      {% endif %}
      <div class="article-meta-full">
        <span class="meta-author">{{ author }}</span>
        <span class="meta-sep">·</span>
        <span class="meta-reading" data-timeago="{{ date | toISOString }}"></span>
      </div>
      <div class="article-tags">
        {% for tag in tags %}
          {% if tag != "article" %}
            <span class="tag">#{{ tag }}</span>
          {% endif %}
        {% endfor %}
      </div>
    </header>
    <div class="article-body">
      {{ content | safe }}
    </div>
    {% if sources and sources.length %}
    <footer class="article-sources">
      <hr class="sources-divider">
      <p><strong>Sources:</strong></p>
      <ul class="sources-list">
        {% for source in sources %}
        <li><a href="{{ source.url }}" target="_blank" rel="noopener">{{ source.title }}</a></li>
        {% endfor %}
      </ul>
    </footer>
    {% endif %}
  </article>
</main>
